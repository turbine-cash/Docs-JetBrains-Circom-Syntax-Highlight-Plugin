---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

<div class="sidebar-marketplace-wrapper">
	<a href="https://plugins.jetbrains.com/plugin/29751-circom-language-support" class="sidebar-marketplace" target="_blank" rel="noopener">
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
			<polyline points="7.5 4.21 12 6.81 16.5 4.21"/>
			<polyline points="7.5 19.79 7.5 14.6 3 12"/>
			<polyline points="21 12 16.5 14.6 16.5 19.79"/>
			<polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
			<line x1="12" y1="22.08" x2="12" y2="12"/>
		</svg>
		Get Plugin
	</a>
</div>

<SidebarPersister>
	<SidebarSublist sublist={sidebar} nested={false} />
</SidebarPersister>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<script>
	// Force all sidebar details elements to be open
	document.addEventListener('DOMContentLoaded', () => {
		const sidebarDetails = document.querySelectorAll('nav.sidebar details, .sidebar-content details, #starlight__sidebar details');
		sidebarDetails.forEach(details => {
			details.setAttribute('open', '');
		});
	});

	// Also run immediately in case DOMContentLoaded already fired
	const sidebarDetails = document.querySelectorAll('nav.sidebar details, .sidebar-content details, #starlight__sidebar details');
	sidebarDetails.forEach(details => {
		details.setAttribute('open', '');
	});
</script>

<style>
	.sidebar-marketplace-wrapper {
		padding: 0.5rem 0;
		margin-bottom: 0.5rem;
	}

	.sidebar-marketplace {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		color: var(--sl-color-gray-2);
		font-size: 0.875rem;
		text-decoration: none;
		border-radius: 0.375rem;
		transition: background-color 0.2s, color 0.2s;
	}

	.sidebar-marketplace:hover {
		background: var(--sl-color-gray-5);
		color: var(--sl-color-white);
	}

	.sidebar-marketplace svg {
		color: var(--sl-color-gray-3);
		flex-shrink: 0;
	}
</style>
